# Copy to .env and fill in. None of these are committed (.env is gitignored).

# --- Research + scripting backend (required) ---------------------------------
# Earworm shells out to the `claude` CLI for research and scripting. The CLI
# reads this key, or you can authenticate the CLI with a Claude subscription
# (`claude login`) and leave this unset.
ANTHROPIC_API_KEY=your-key-here

# --- Publishing to the optional Cloudflare feed (optional) -------------------
# These override config/secrets.toml when set.
CLOUDFLARE_API_TOKEN=
EARWORM_INGEST_SECRET=
EARWORM_FEED_TOKEN=
